{
  "version": 2,
  "routes": [
    {
      "src": "/api/complaint",
      "dest": "/server.js"
    },
    {
      "src": "/feedback",
      "dest": "/feedback/index.html"
    },
    {
      "src": "/complaint",
      "dest": "/feedback/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}